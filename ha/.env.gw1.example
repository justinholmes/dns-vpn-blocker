# Copy to .env on gw1 and fill in your values
# docker compose --env-file .env --profile ha up -d

# This node's real LAN IP (used as BIRD router-id)
NODE_IP=192.168.1.10

# LAN interface to monitor (eth1, enp2s0, etc.)
LAN_IFACE=eth1

# Shared Virtual IP announced via BGP
VIP=192.168.1.254

# BGP session to upstream router
BGP_UPSTREAM_IP=192.168.1.1
BGP_UPSTREAM_AS=65000
BGP_LOCAL_AS=65001

# Health check tuning
HEALTH_INTERVAL=3
FAILOVER_THRESH=2
